<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bgblack">

    <!-- Header with back button and search input -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/btnBackSearch"
            android:layout_width="@dimen/dp_45"
            android:layout_height="@dimen/dp_45"
            android:layout_marginLeft="@dimen/dp_15"
            android:contentDescription="Back"
            android:elevation="10dp"
            android:paddingLeft="0dp"
            android:paddingTop="@dimen/dp_10"
            android:paddingRight="@dimen/dp_20"
            android:paddingBottom="@dimen/dp_10"
            android:src="@drawable/backarrow"
            android:translationZ="10dp"
            android:visibility="visible"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />


        <EditText
            android:id="@+id/searchEditText"
            android:layout_width="0dp"
            android:layout_height="@dimen/dp_45"
            android:layout_weight="1"

            android:layout_marginEnd="@dimen/dp_8"
            android:background="@drawable/search_bg_rounded"
            android:hint="Search songs..."
            android:textColorHint="@color/gray"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_16"
            android:paddingStart="@dimen/dp_16"
            android:paddingEnd="@dimen/dp_16"
            android:maxLines="1"
            android:singleLine="true"
            android:inputType="text"
            android:imeOptions="actionSearch" />

        <TextView
            android:id="@+id/tvSongCount"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="0 songs"
            android:textColor="@color/gray"
            android:textSize="@dimen/sp_14"
            android:layout_marginEnd="@dimen/dp_8"
            android:visibility="gone" />

        <ImageView
            android:id="@+id/tvCancel"
            android:layout_width="@dimen/dp_24"
            android:layout_height="@dimen/dp_24"
            android:src="@drawable/close_y"
            android:layout_marginRight="@dimen/dp_15"
            android:tint="@color/white"
            android:layout_gravity="center_vertical"
            />
    </LinearLayout>

    <!-- Search Results -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/searchRecyclerView"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="@dimen/dp_8"
        android:visibility="gone" />

    <!-- Empty State -->
    <LinearLayout
        android:id="@+id/emptyStateLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="@dimen/dp_32">

        <ImageView
            android:layout_width="@dimen/dp_120"
            android:layout_height="@dimen/dp_120"
            android:src="@drawable/search"
            android:tint="@color/gray"
            android:layout_marginBottom="@dimen/dp_24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Search for songs"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_18"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/dp_8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Find your favorite songs in this playlist"
            android:textColor="@color/gray"
            android:textSize="@dimen/sp_14"
            android:gravity="center" />
    </LinearLayout>

    <!-- No Results Found -->
    <LinearLayout
        android:id="@+id/noResultsLayout"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone"
        android:padding="@dimen/dp_32">

        <ImageView
            android:layout_width="@dimen/dp_120"
            android:layout_height="@dimen/dp_120"
            android:src="@drawable/common_full_open_on_phone"
            android:tint="@color/gray"
            android:layout_marginBottom="@dimen/dp_24" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="No results found"
            android:textColor="@color/white"
            android:textSize="@dimen/sp_18"
            android:textStyle="bold"
            android:layout_marginBottom="@dimen/dp_8" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Try searching with different keywords"
            android:textColor="@color/gray"
            android:textSize="@dimen/sp_14"
            android:gravity="center" />
    </LinearLayout>

</LinearLayout>