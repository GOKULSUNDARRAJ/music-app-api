<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:paddingRight="@dimen/dp_10"
    android:paddingBottom="@dimen/dp_10"
    android:paddingTop="@dimen/dp_10"
    android:gravity="center_vertical">

    <!-- Album Art with ProgressBar -->
    <FrameLayout
        android:id="@+id/imageContainer"
        android:layout_width="@dimen/dp_45"
        android:layout_height="@dimen/dp_45"
        android:layout_marginEnd="@dimen/dp_8"
        android:layout_alignParentStart="true"
        android:layout_centerVertical="true">

        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            app:cardCornerRadius="@dimen/dp_8"
            app:cardElevation="4dp">

            <ImageView
                android:id="@+id/imgAudioArt"
                android:layout_width="match_parent"
                android:layout_height="match_parent"
                android:scaleType="centerCrop"
                android:src="@drawable/video_placholder" />

            <ProgressBar
                android:id="@+id/imageProgress"
                style="?android:attr/progressBarStyleSmall"
                android:layout_width="@dimen/dp_20"
                android:layout_height="@dimen/dp_20"
                android:progressTint="@color/bgred"
                android:indeterminateTint="@color/bgred"
                android:layout_gravity="center"
                android:visibility="gone" />
        </androidx.cardview.widget.CardView>

        <!-- Offline Indicator -->
        <ImageView
            android:id="@+id/offlineIndicator"
            android:layout_width="12dp"
            android:layout_height="12dp"
            android:layout_gravity="top|end"
            android:layout_margin="2dp"
            android:contentDescription="Offline"
            android:visibility="gone"
            android:padding="1dp" />

    </FrameLayout>

    <!-- Audio Info -->
    <LinearLayout
        android:id="@+id/textContainer"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_toEndOf="@id/imageContainer"
        android:layout_toStartOf="@+id/menuContainer"
        android:layout_centerVertical="true"
        android:orientation="vertical"
        android:paddingStart="@dimen/dp_8">

        <TextView
            android:id="@+id/audioTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Audio Title"
            android:textColor="@color/white"
            android:fontFamily="@font/circularstdmedium"
            android:textSize="@dimen/dp_16"
            android:maxLines="1"
            android:ellipsize="end" />

        <TextView
            android:id="@+id/audioArtist"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Artist Name"
            android:fontFamily="@font/circularstdbook"
            android:textSize="@dimen/sp_14"
            android:textColor="@color/placeholder"
            android:maxLines="1"
            android:ellipsize="end" />
    </LinearLayout>

    <!-- Menu and Play button container -->
    <LinearLayout
        android:id="@+id/menuContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentEnd="true"
        android:layout_centerVertical="true"
        android:orientation="horizontal"
        android:gravity="center">

        <!-- Wave Animation Container -->
        <LinearLayout
            android:id="@+id/waveContainer"
            android:layout_width="25dp"
            android:layout_height="25dp"
            android:layout_marginEnd="8dp"
            android:gravity="center"
            android:orientation="horizontal"
            android:visibility="gone">

            <View
                android:id="@+id/bar1"
                android:layout_width="3dp"
                android:layout_height="10dp"
                android:layout_margin="1dp"
                android:background="@color/green"/>

            <View
                android:id="@+id/bar2"
                android:layout_width="3dp"
                android:layout_height="14dp"
                android:layout_margin="1dp"
                android:background="@color/green"/>

            <View
                android:id="@+id/bar3"
                android:layout_width="3dp"
                android:layout_height="18dp"
                android:layout_margin="1dp"
                android:background="@color/green"/>

        </LinearLayout>

        <!-- Play/Pause button -->
        <ImageView
            android:id="@+id/playButton"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:layout_marginEnd="8dp"
            android:padding="@dimen/dp_5"
            android:src="@drawable/play_player"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:contentDescription="Play Audio" />

        <!-- Menu icon -->
        <ImageView
            android:id="@+id/menu"
            android:layout_width="@dimen/dp_40"
            android:layout_height="@dimen/dp_40"
            android:padding="@dimen/dp_10"
            android:src="@drawable/dots"
            android:contentDescription="Menu" />

    </LinearLayout>

</RelativeLayout>